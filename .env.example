APP_ENV=production
APP_NAME=Xego
PUBLIC_HOST=203-0-113-10.sslip.io
BASE_URL=https://203-0-113-10.sslip.io
LOG_LEVEL=info

# PostgreSQL is private to Docker Compose.
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Generate with: go run ./cmd/demo hash-password
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH='$2a$10$replace_with_a_real_bcrypt_hash'

# Paystack TEST secret key only. The service rejects non-test verifications.
PAYSTACK_SECRET_KEY=sk_test_replace_me
PAYSTACK_BASE_URL=https://api.paystack.co

# Meta WhatsApp Cloud API.
WHATSAPP_VERIFY_TOKEN=replace-with-a-random-webhook-token
WHATSAPP_APP_SECRET=replace-with-meta-app-secret
WHATSAPP_ACCESS_TOKEN=replace-with-system-user-access-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-phone-number-id
# Set this to the currently supported version shown by Meta when configuring the app.
WHATSAPP_GRAPH_VERSION=vXX.X
WHATSAPP_STATUS_TEMPLATE=payment_status_update
WHATSAPP_TEMPLATE_LOCALE=en

# Telegram Bot API. Enable only after creating a bot and setting the webhook.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=replace-with-random-telegram-webhook-secret
TELEGRAM_API_BASE=https://api.telegram.org

# SMS request-code webhook. Enable after configuring an inbound SMS provider.
SMS_ENABLED=false
SMS_PROVIDER=webhook
SMS_WEBHOOK_SECRET=replace-with-random-sms-webhook-secret
SMS_SENDER_ID=Xego
SMS_API_BASE=
SMS_API_KEY=

# Mobile data fulfilment. Use "simulated" locally or "vtpass" for VTPass sandbox.
DATA_PROVIDER=simulated
VTPASS_BASE_URL=https://sandbox.vtpass.com/api
VTPASS_API_KEY=
VTPASS_PUBLIC_KEY=
VTPASS_SECRET_KEY=
VTPASS_WEBHOOK_SECRET=
VTPASS_TIMEOUT=45s

PAYMENT_MIN_KOBO=10000
PAYMENT_MAX_KOBO=10000000
RETENTION_PERIOD=2160h
CONVERSATION_TTL=30m
RECEIPT_TTL=2160h
